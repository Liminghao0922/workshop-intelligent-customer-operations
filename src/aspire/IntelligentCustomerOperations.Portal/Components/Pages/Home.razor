@page "/"
@inject ApiClient ApiClient

<PageTitle>Dashboard</PageTitle>

<h1>Call Session Dashboard</h1>

@if (daily is null || fcr is null)
{
	<p>Loading metrics...</p>
}
else
{
	<div class="row g-3 mb-4">
		<div class="col-md-4">
			<div class="card p-3">
				<h5>Total Sessions (@daily.Days days)</h5>
				<p class="display-6 mb-0">@daily.Total</p>
			</div>
		</div>
		<div class="col-md-4">
			<div class="card p-3">
				<h5>Resolved on First Call</h5>
				<p class="display-6 mb-0">@fcr.ResolvedOnFirstCall</p>
			</div>
		</div>
		<div class="col-md-4">
			<div class="card p-3">
				<h5>FCR Rate</h5>
				<p class="display-6 mb-0">@((fcr.Fcr * 100).ToString("0.0"))%</p>
			</div>
		</div>
	</div>

	<h4>Daily Session Growth</h4>
	<table class="table table-striped">
		<thead>
			<tr>
				<th>Date</th>
				<th>Sessions</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var point in daily.Points)
			{
				<tr>
					<td>@point.Date</td>
					<td>@point.Count</td>
				</tr>
			}
		</tbody>
	</table>
}

@code {
	private DailyMetricsView? daily;
	private FcrMetricsView? fcr;

	protected override async Task OnInitializedAsync()
	{
		daily = await ApiClient.GetDailyMetricsAsync();
		fcr = await ApiClient.GetFcrMetricsAsync();
	}
}
